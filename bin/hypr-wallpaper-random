#!/usr/bin/env bash
set -euo pipefail

PATH="$HOME/.nix-profile/bin:/etc/profiles/per-user/$USER/bin:/run/current-system/sw/bin:/usr/bin:/bin:$PATH"
wallpapers_dir="$HOME/.local/share/wallpapers/rotation"
lock_file="${XDG_RUNTIME_DIR:-/tmp}/hypr-wallpaper-random.lock"

# Serialize wallpaper changes to avoid swaybg process races.
exec 9>"$lock_file"
flock -w 2 9 || exit 0

# No-op outside Wayland/Hyprland sessions (e.g. from a plain TTY switch).
if [ -z "${WAYLAND_DISPLAY:-}" ] && [ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
  exit 0
fi

if [ ! -d "$wallpapers_dir" ]; then
  exit 0
fi

mapfile -d '' images < <(find -L "$wallpapers_dir" -maxdepth 1 -type f \
  \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) -print0)

if [ "${#images[@]}" -eq 0 ]; then
  exit 0
fi

selected="${images[$((RANDOM % ${#images[@]}))]}"

pkill -TERM -x swaybg >/dev/null 2>&1 || true
for _ in {1..20}; do
  pgrep -x swaybg >/dev/null 2>&1 || break
  sleep 0.05
done
pgrep -x swaybg >/dev/null 2>&1 && pkill -KILL -x swaybg >/dev/null 2>&1 || true

(swaybg -i "$selected" -m fill >/dev/null 2>&1 &)
